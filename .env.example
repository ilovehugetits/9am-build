WEBHOOK_SECRET=your-github-webhook-secret
PORT=9000
DISCORD_CHANGELOG_WEBHOOK=your-discord-webhook-url
GITHUB_TOKEN=your-github-personal-access-token
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Requires Playwright's Chromium: run `bunx playwright install chromium` once
# after `bun install` (the Docker image does this automatically).
# Set to 1 only when running as root in a container (Docker sets it for you).
# Leave unset locally so the Chromium sandbox stays enabled.
# CHROMIUM_NO_SANDBOX=1
